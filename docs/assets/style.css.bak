body {
    font-family: Georgia, serif;
    max-width: 720px;
    margin: auto;
    padding: 2rem;
    background: #111;
    color: #eee;
    line-height: 1.7;
}

a {
    color: #c9a84c;
    text-decoration: none;
}

a:hover {
    text-decoration: underline;
}

nav {
    margin-bottom: 1.5rem;
}

nav a {
    margin-right: 12px;
}

hr {
    border: 0;
    border-top: 1px solid #444;
    margin: 2rem 0;
}

h1 {
    font-size: 1.8rem;
}

h2 {
    margin-top: 1.5rem;
}

ul {
    padding-left: 1.2rem;
}

li {
    margin-bottom: 0.5rem;
}
.resource-list {
    display: grid;
    gap: 1rem;
    margin-top: 1.5rem;
}

.resource-card {
    border: 1px solid #444;
    padding: 1rem;
    background: #181818;
}

.resource-card h3 {
    margin: 0.25rem 0;
}

.resource-card p {
    margin: 0.5rem 0;
    color: #ccc;
}

.resource-type {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #c9a84c;
}

.resource-url {
    font-size: 0.8rem;
    color: #888;
    word-break: break-all;
}
.resource-group {
    margin-top: 2rem;
}

.resource-group h3 {
    color: #c9a84c;
    margin-bottom: 1rem;
    border-bottom: 1px solid #444;
    padding-bottom: 0.4rem;
}